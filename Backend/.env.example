# Backend deployment environment variables
# Copy this file to .env and adapt values per environment (dev/staging/prod)
# For Docker container + external DB on same host, prefer host.docker.internal

DB_URL=jdbc:postgresql://host.docker.internal:5432/mobile?createDatabaseIfNotExist=true
DB_USERNAME=postgres
DB_PASSWORD=change_me

JPA_DDL_AUTO=update
SERVER_PORT=8020

FILE_UPLOAD_DIR=/srv/mobile-data/uploads
APK_STORAGE_DIR=/srv/mobile-data/apk
